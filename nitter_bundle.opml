    </outline>

    <outline text="Allowlist - Policy / Think Tanks (More)" title="Allowlist - Policy / Think Tanks (More)">
      <outline text="@SIPRIorg" type="rss" xmlUrl="https://nitter.poast.org/SIPRIorg/rss" />
      <outline text="@IISS_org" type="rss" xmlUrl="https://nitter.poast.org/IISS_org/rss" />
      <outline text="@ChathamHouse" type="rss" xmlUrl="https://nitter.poast.org/ChathamHouse/rss" />
      <outline text="@CFR_org" type="rss" xmlUrl="https://nitter.poast.org/CFR_org/rss" />
      <outline text="@RUSI_org" type="rss" xmlUrl="https://nitter.poast.org/RUSI_org/rss" />
      <outline text="@CrisisGroup" type="rss" xmlUrl="https://nitter.poast.org/CrisisGroup/rss" />
    </outline>

    <outline text="Allowlist - Conflict Data / Monitors (More)" title="Allowlist - Conflict Data / Monitors (More)">
      <outline text="@ACLEDINFO" type="rss" xmlUrl="https://nitter.poast.org/ACLEDINFO/rss" />
    </outline>

  </body>
